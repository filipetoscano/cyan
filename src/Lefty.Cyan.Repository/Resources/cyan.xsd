<?xml version="1.0" encoding="utf-8"?>
<xsd:schema
  xmlns="urn:cyan"
  targetNamespace="urn:cyan"
  xmlns:tns="urn:cyan"
  elementFormDefault="qualified"
  xmlns:xsd="http://www.w3.org/2001/XMLSchema">


  <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
  ~
  ~ Azure
  ~
  ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
  <xsd:element name="azure">
    <xsd:complexType>
      <xsd:sequence>
        <xsd:element name="subscription" minOccurs="0" maxOccurs="unbounded">
          <xsd:complexType>
            <xsd:sequence>
              <xsd:element name="resourceGroup" minOccurs="0" maxOccurs="unbounded">
                <xsd:complexType>
                  <xsd:choice minOccurs="0" maxOccurs="unbounded">
                    <xsd:element name="acr" type="tns:resource" />
                    <xsd:element name="aks" type="tns:resource" />
                    <xsd:element name="appInsights" type="tns:resource" />
                    <xsd:element name="dataBricks" type="tns:resource" />
                    <xsd:element name="eventHub" type="tns:resource" />
                    <xsd:element name="keyVault" type="tns:resource" />
                    <xsd:element name="logAnalyticsWorkspace" type="tns:resource" />
                    <xsd:element name="netAppFiles" type="tns:resource" />
                    <xsd:element name="postgres" type="tns:resource" />
                    <xsd:element name="redis" type="tns:resource" />
                    <xsd:element name="sqlServer" type="tns:resource" />
                    <xsd:element name="storage" type="tns:resource" />
                  </xsd:choice>

                  <xsd:attribute name="name" type="xsd:string" use="required" />
                  <xsd:attribute name="allow" type="xsd:boolean" use="optional" default="true" />
                  <xsd:attribute name="types" type="tns:rbacTypeList" use="optional" default="permanent" />
                </xsd:complexType>
              </xsd:element>
            </xsd:sequence>

            <xsd:attribute name="name" type="xsd:string" use="required" />
            <xsd:attribute name="allow" type="xsd:boolean" use="optional" default="true" />
            <xsd:attribute name="types" type="tns:rbacTypeList" use="optional" default="permanent" />
          </xsd:complexType>
        </xsd:element>
      </xsd:sequence>
    </xsd:complexType>
  </xsd:element>


  <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
  ~
  ~ Company
  ~
  ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
  <xsd:element name="company">
    <xsd:complexType>
      <xsd:sequence>
        <xsd:element name="name" type="xsd:string" />
        <xsd:element name="description" type="xsd:string" />
      </xsd:sequence>
    </xsd:complexType>
  </xsd:element>


  <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
  ~
  ~ Devops
  ~
  ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
  <xsd:element name="devops">
    <xsd:complexType>
      <xsd:sequence>
        <xsd:element name="project" minOccurs="0" maxOccurs="unbounded">
          <xsd:complexType>
            <xsd:sequence>
              <xsd:element name="description" type="xsd:string" minOccurs="0" />

              <xsd:element name="group" minOccurs="0" maxOccurs="unbounded">
                <xsd:complexType>
                  <xsd:attribute name="name" type="xsd:string" use="required" />
                </xsd:complexType>
              </xsd:element>

              <xsd:element name="team" minOccurs="0" maxOccurs="unbounded">
                <xsd:complexType>
                  <xsd:attribute name="name" type="xsd:string" use="required" />
                </xsd:complexType>
              </xsd:element>

              <xsd:element name="repository" minOccurs="0" maxOccurs="unbounded">
                <xsd:complexType>
                  <xsd:attribute name="name" type="xsd:string" use="required" />
                </xsd:complexType>
              </xsd:element>
            </xsd:sequence>
            <xsd:attribute name="name" type="xsd:string" use="required" />
          </xsd:complexType>
        </xsd:element>
      </xsd:sequence>
    </xsd:complexType>
  </xsd:element>


  <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
  ~
  ~ DNS
  ~
  ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
  <xsd:element name="dns">
    <xsd:complexType>
      <xsd:sequence>
        <xsd:element name="environmentList" type="dnsEnvironmentList" minOccurs="0" maxOccurs="unbounded">
          <xsd:unique name="uqEnvListEnvs">
            <xsd:selector xpath=" tns:environment " />
            <xsd:field xpath=" @name" />
          </xsd:unique>

          <xsd:unique name="uqEnvListHosts">
            <xsd:selector xpath=" tns:*/tns:host " />
            <xsd:field xpath=" @name" />
          </xsd:unique>
        </xsd:element>

        <xsd:element name="environment" type="dnsEnvironment" minOccurs="0" maxOccurs="unbounded">
          <xsd:unique name="uqEnvHosts">
            <xsd:selector xpath=" tns:*/tns:host " />
            <xsd:field xpath=" @name" />
          </xsd:unique>
        </xsd:element>
      </xsd:sequence>
    </xsd:complexType>

    <xsd:unique name="uqEnvs">
      <xsd:selector xpath=" tns:environment " />
      <xsd:field xpath=" @name" />
    </xsd:unique>
  </xsd:element>


  <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
  ~
  ~ Entra
  ~
  ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
  <xsd:element name="entra">
    <xsd:complexType>
      <xsd:sequence>
        <xsd:element name="group" minOccurs="0" maxOccurs="unbounded">
          <xsd:complexType>
            <xsd:sequence>
              <xsd:element name="description" type="xsd:string" minOccurs="0" />
              <xsd:element name="purpose" type="xsd:string" minOccurs="0" />
            </xsd:sequence>

            <xsd:attribute name="name" type="xsd:string" use="required" />
          </xsd:complexType>
        </xsd:element>
      </xsd:sequence>
    </xsd:complexType>

    <xsd:unique name="uqGroup">
      <xsd:selector xpath=" tns:group " />
      <xsd:field xpath=" @name " />
    </xsd:unique>
  </xsd:element>


  <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
  ~
  ~ Firewall
  ~
  ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
  <xsd:element name="firewall">
    <xsd:complexType>
      <xsd:sequence>
      </xsd:sequence>
    </xsd:complexType>
  </xsd:element>


  <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
  ~
  ~ Jump servers
  ~
  ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
  <xsd:element name="jump">
    <xsd:complexType>
      <xsd:sequence>
        <xsd:element name="jump" minOccurs="0" maxOccurs="unbounded">
          <xsd:complexType>
            <xsd:sequence>
              <xsd:element name="description" type="xsd:string" minOccurs="0" />
            </xsd:sequence>

            <xsd:attribute name="server" type="xsd:string" use="required" />
          </xsd:complexType>
        </xsd:element>
      </xsd:sequence>
    </xsd:complexType>

    <xsd:unique name="uqJumpServer">
      <xsd:selector xpath=" tns:jump " />
      <xsd:field xpath=" @server " />
    </xsd:unique>
  </xsd:element>


  <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
  ~
  ~ Person
  ~
  ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
  <xsd:element name="person">
    <xsd:complexType>
      <xsd:sequence>
        <xsd:element name="id" type="xsd:string" minOccurs="0" />
        <xsd:element name="username" type="xsd:string" minOccurs="0" />
        <xsd:element name="name" type="xsd:string" />
        <xsd:element name="expires" type="xsd:date" />
        <xsd:element name="enabled" type="xsd:boolean" minOccurs="0" />

        <xsd:element name="email" type="xsd:string" minOccurs="0" />
        <xsd:element name="phone" type="xsd:string" minOccurs="0" />
        <xsd:element name="role" type="xsd:string" minOccurs="0" />
      </xsd:sequence>
    </xsd:complexType>
  </xsd:element>


  <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
  ~
  ~ RBAC
  ~
  ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
  <xsd:element name="rbac">
    <xsd:complexType>
      <xsd:sequence>
        <xsd:element name="window" minOccurs="0">
          <xsd:complexType>
            <xsd:attribute name="from" type="xsd:date" use="required" />
            <xsd:attribute name="to" type="xsd:date" use="required" />
          </xsd:complexType>
        </xsd:element>

        <xsd:element name="vpn" minOccurs="0" maxOccurs="unbounded">
          <xsd:complexType />
        </xsd:element>

        <xsd:element name="jump" minOccurs="0" maxOccurs="unbounded">
          <xsd:complexType>
            <xsd:attribute name="server" type="xsd:string" use="required" />
          </xsd:complexType>
        </xsd:element>

        <xsd:element name="azure" minOccurs="0">
          <xsd:complexType>
            <xsd:choice minOccurs="0" maxOccurs="unbounded">
              <xsd:element name="acr" type="tns:roleAssignment" />
              <xsd:element name="aks" type="tns:roleAssignment" />
              <xsd:element name="appInsights" type="tns:roleAssignment" />
              <xsd:element name="dataBricks" type="tns:roleAssignment" />
              <xsd:element name="eventHub" type="tns:roleAssignment" />
              <xsd:element name="keyVault" type="tns:roleAssignment" />
              <xsd:element name="logAnalyticsWorkspace" type="tns:roleAssignment" />
              <xsd:element name="netAppFiles" type="tns:roleAssignment" />
              <xsd:element name="postgres" type="tns:roleAssignment" />
              <xsd:element name="redis" type="tns:roleAssignment" />
              <xsd:element name="resourceGroup" type="tns:roleAssignment" />
              <xsd:element name="sqlServer" type="tns:roleAssignment" />
              <xsd:element name="storage" type="tns:roleAssignment" />
              <xsd:element name="subscription" type="tns:roleAssignment" />
            </xsd:choice>
          </xsd:complexType>
        </xsd:element>

        <xsd:element name="devops">
          <xsd:complexType>
            <xsd:sequence>
              <xsd:element name="project" type="tns:projectRbac" minOccurs="0" maxOccurs="unbounded" />
            </xsd:sequence>

            <xsd:attribute name="access" type="tns:devopsAccessType" use="required" />
          </xsd:complexType>
        </xsd:element>

        <xsd:element name="entra" minOccurs="0">
          <xsd:complexType>
            <xsd:sequence>
              <xsd:element name="group" minOccurs="0" maxOccurs="unbounded">
                <xsd:complexType>
                  <xsd:attribute name="name" type="xsd:string" use="required" />
                </xsd:complexType>
              </xsd:element>
            </xsd:sequence>
          </xsd:complexType>
        </xsd:element>
      </xsd:sequence>
    </xsd:complexType>

    <xsd:key name="uqJumpServers">
      <xsd:selector xpath=" tns:jump " />
      <xsd:field xpath=" @server " />
    </xsd:key>

    <xsd:key name="uqEntraGroup">
      <xsd:selector xpath=" tns:entra/tns:group " />
      <xsd:field xpath=" @name " />
    </xsd:key>

    <xsd:key name="uqDevopsProjects">
      <xsd:selector xpath=" tns:devops/tns:project " />
      <xsd:field xpath=" @name " />
    </xsd:key>

    <xsd:key name="uqAzureResx">
      <xsd:selector xpath=" tns:azure/tns:* " />
      <xsd:field xpath=" @name " />
      <xsd:field xpath=" @role " />
    </xsd:key>
  </xsd:element>


  <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
  ~
  ~ Complex
  ~
  ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
  <xsd:complexType name="companyPerson">
    <xsd:sequence>
      <xsd:element name="name" type="xsd:string" />
      <xsd:element name="expires" type="xsd:date" />
    </xsd:sequence>

    <xsd:attribute name="id" type="tns:personId" use="optional" />
    <xsd:attribute name="username" type="tns:personUsername" use="optional" />
  </xsd:complexType>

  <xsd:complexType name="dnsEnvironment">
    <xsd:sequence>
      <xsd:element name="internal" type="tns:dnsZone" minOccurs="0" />
      <xsd:element name="public-hold" type="tns:dnsZone" minOccurs="0" />
      <xsd:element name="public" type="tns:dnsZone" minOccurs="0" />
    </xsd:sequence>

    <xsd:attribute name="name" type="environmentNameType" use="required" />
  </xsd:complexType>

  <xsd:complexType name="dnsEnvironmentList">
    <xsd:sequence>
      <xsd:element name="environment" maxOccurs="unbounded">
        <xsd:complexType>
          <xsd:attribute name="name" type="tns:environmentNameType" use="required" />
        </xsd:complexType>
      </xsd:element>

      <xsd:element name="internal" type="tns:dnsZone" minOccurs="0" />
      <xsd:element name="public-hold" type="tns:dnsZone" minOccurs="0" />
      <xsd:element name="public" type="tns:dnsZone" minOccurs="0" />
    </xsd:sequence>
  </xsd:complexType>

  <xsd:complexType name="dnsHost">
    <xsd:attribute name="name" type="xsd:string" use="required" />
  </xsd:complexType>

  <xsd:complexType name="dnsZone">
    <xsd:sequence>
      <xsd:element name="host" type="tns:dnsHost" minOccurs="0" maxOccurs="unbounded" />
    </xsd:sequence>
  </xsd:complexType>

  <xsd:complexType name="projectRbac">
    <xsd:sequence>
      <xsd:element name="group" minOccurs="0" maxOccurs="unbounded">
        <xsd:complexType>
          <xsd:attribute name="name" type="xsd:string" use="required" />
        </xsd:complexType>
      </xsd:element>

      <xsd:element name="team" minOccurs="0" maxOccurs="unbounded">
        <xsd:complexType>
          <xsd:attribute name="name" type="xsd:string" use="required" />
        </xsd:complexType>
      </xsd:element>
    </xsd:sequence>

    <xsd:attribute name="name" type="tns:projectNameType" use="required" />
  </xsd:complexType>

  <xsd:complexType name="resource">
    <xsd:attribute name="name" type="xsd:string" use="required" />
    <xsd:attribute name="types" type="tns:rbacTypeList" use="optional" default="permanent" />
  </xsd:complexType>

  <xsd:complexType name="roleAssignment">
    <xsd:attribute name="name" type="xsd:string" use="required" />
    <xsd:attribute name="role" type="xsd:string" use="required" />
    <xsd:attribute name="type" type="tns:rbacType" use="optional" default="permanent" />
  </xsd:complexType>


  <!-- ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
  ~
  ~ Simple
  ~
  ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~ -->
  <xsd:simpleType name="devopsAccessType">
    <xsd:restriction base="xsd:string">
      <xsd:enumeration value="Basic" />
      <xsd:enumeration value="Stakeholder" />
    </xsd:restriction>
  </xsd:simpleType>

  <xsd:simpleType name="environmentNameType">
    <xsd:restriction base="xsd:string" />
  </xsd:simpleType>

  <xsd:simpleType name="personId">
    <xsd:restriction base="xsd:string">
      <xsd:minLength value="1" />
    </xsd:restriction>
  </xsd:simpleType>

  <xsd:simpleType name="personUsername">
    <xsd:restriction base="xsd:string">
      <xsd:minLength value="1" />
    </xsd:restriction>
  </xsd:simpleType>

  <xsd:simpleType name="projectNameType">
    <xsd:restriction base="xsd:string" />
  </xsd:simpleType>

  <xsd:simpleType name="rbacType">
    <xsd:restriction base="xsd:string">
      <xsd:enumeration value="eligible">
        <xsd:annotation>
          <xsd:documentation>Eligible assignment of RBAC (through PIM)</xsd:documentation>
        </xsd:annotation>
      </xsd:enumeration>

      <xsd:enumeration value="permanent">
        <xsd:annotation>
          <xsd:documentation>Permanent assignment of RBAC.</xsd:documentation>
        </xsd:annotation>
      </xsd:enumeration>
    </xsd:restriction>
  </xsd:simpleType>

  <xsd:simpleType name="rbacTypeList">
    <xsd:list itemType="tns:rbacType" />
  </xsd:simpleType>

  <xsd:simpleType name="repositoryNameType">
    <xsd:restriction base="xsd:string" />
  </xsd:simpleType>

</xsd:schema>